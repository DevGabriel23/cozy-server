---
// src/components/AddonsGrid.astro
import { getCollection } from "astro:content";
import { generateAddonImageFallback } from "../utils/imageUtils";
import AddonCard from "./AddonCard.astro";

const addons = await getCollection("addons");
---

<section class="py-12 pb-20 px-4 max-w-5xl mx-auto bg-canvas">
	<h2
		class="font-heading text-3xl md:text-4xl font-medium text-ink-primary text-center mb-8"
	>
		Contenido
	</h2>
	<div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
		{addons.map((item) => <AddonCard item={item} variant="grid" />)}
	</div>
</section>
