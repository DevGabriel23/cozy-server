---
// src/components/AddonsGrid.astro
import { getCollection } from "astro:content";

const addons = await getCollection("addons");
---

<section class="py-12 pb-20 px-4 max-w-5xl mx-auto bg-canvas">
	<h2
		class="font-heading text-3xl md:text-4xl font-medium text-ink-primary text-center mb-8"
	>
		Contenido
	</h2>
	<div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
		{
			addons.map((item) => {
				const bgColors = ["8A9A5B", "D4A373", "DCE3C8", "E8D3D0"];
				const textColors = ["FAF6F0", "4A4036"];
				const uriEncodedTitle = encodeURIComponent(item.data.title);
				const bgColorIndex = Math.floor(
					Math.random() * bgColors.length,
				);
				const textColorIndex = Math.floor(
					Math.random() * textColors.length,
				);
				const fallbackImage = `https://placehold.co/600x400/${bgColors[bgColorIndex]}/${textColors[textColorIndex]}?text=${uriEncodedTitle}`;

				const finalImage = item.data.mainImage
					? `/images/${item.data.mainImage}`
					: fallbackImage;

				return (
					<a
						href={`/${item.collection}/${item.id}`}
						class="flex flex-col bg-canvas border border-hairline rounded-lg overflow-hidden shadow-(--shadow-soft) hover:shadow-(--shadow-hover) hover:-translate-y-1 transition-all duration-300 group"
					>
						<img
							src={finalImage}
							alt={item.data.title}
							class="w-full aspect-video object-cover block group-hover:scale-105 transition-transform duration-500 ease-out"
						/>
						<div class="p-6 flex-1 flex flex-col gap-2 relative z-10 bg-canvas">
							<span class="inline-block self-start bg-brand-sage-soft text-brand-sage-deep font-body text-sm font-medium px-3 py-1 rounded-full">
								{item.data.type}
							</span>
							<h3 class="font-heading text-2xl font-medium text-ink-primary mt-1">
								{item.data.title}
							</h3>
							<p class="font-body text-base text-ink-secondary leading-relaxed line-clamp-3">
								{item.data.description}
							</p>
						</div>
					</a>
				);
			})
		}
	</div>
</section>
